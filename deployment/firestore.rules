rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read and write their own user data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Users can read and write their own settings
    match /userSettings/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Problems collection is read-only for all authenticated users
    match /problems/{problemId} {
      allow read: if request.auth != null;
      allow write: if false; // Only allow manual updates via Firebase Console or scripts
    }
    
    // Deny all other reads and writes
    match /{document=**} {
      allow read, write: if false;
    }
  }
}