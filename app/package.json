{
  "name": "leetcode-problem-recommender",
  "version": "1.0.0",
  "private": true,
  "description": "A clean, modern LeetCode problem recommender built with Next.js and Firebase",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "clean": "rmdir /s /q .next build 2>nul || rm -rf .next build 2>/dev/null || echo 'Cleaned'"
  },
  "dependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "firebase": "^10.12.2",
    "next": "14.2.5",
    "postcss": "^8",
    "react": "^18",
    "react-dom": "^18",
    "tailwindcss": "^3.3.0",
    "typescript": "^5"
  },
  "devDependencies": {
    "eslint": "^8",
    "eslint-config-next": "14.2.5"
  },
  "keywords": ["leetcode", "problem-recommender", "nextjs", "firebase", "react"],
  "author": "",
  "license": "MIT"
}